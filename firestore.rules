rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // User profiles
    match /users/{userId} {
      allow read, write: if isSignedIn();
    }

    // Campaign Content (Public Read, Auth Write)
    match /program/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    match /conferences/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    match /team/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /homepageBlocks/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    // Supporters (Public Create with strict validations, Admin read/delete)
    match /supporters/{id} {
      allow create: if request.resource.data.keys().hasAll(['fullName', 'academicLevel', 'fieldOfStudy', 'phone', 'email', 'createdAt'])
        && request.resource.data.keys().size() == 6
        && request.resource.data.fullName is string
        && request.resource.data.fullName.size() <= 100
        && request.resource.data.academicLevel is string
        && request.resource.data.academicLevel.size() <= 50
        && request.resource.data.fieldOfStudy is string
        && request.resource.data.fieldOfStudy.size() <= 100
        && request.resource.data.phone is string
        && request.resource.data.phone.size() <= 30
        && request.resource.data.email is string
        && request.resource.data.email.size() <= 100
        && request.resource.data.createdAt == request.time;
      allow read, delete: if isSignedIn();
    }
    
    // Finance Transactions (Only authenticated admin can read, write)
    match /financeTransactions/{id} {
      allow read, write: if isSignedIn();
    }

    // Finance Goals (Only authenticated admin can read, write)
    match /financeGoals/{id} {
      allow read, write: if isSignedIn();
    }

    // Agenda Events & Notes (Only authenticated admin can read, write)
    match /agendaEvents/{id} {
      allow read, write: if isSignedIn();
    }
    match /agendaNotes/{id} {
      allow read, write: if isSignedIn();
    }
    
    // Health check
    match /system/health {
      allow read: if true;
    }
  }
}
